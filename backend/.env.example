APP_NAME=OmniAI
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000

JWT_SECRET_KEY=dev-only-change-me-before-production
JWT_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001

# LLM provider: groq (production default) | openai | ollama (local dev)
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant
GROQ_REASONING_MODEL=llama-3.3-70b-versatile
GROQ_GEMMA_MODEL=gemma2-9b-it
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Automatic model selection by mode/query (explicit model param still honored)
MODEL_ROUTING_ENABLED=true

# Optional — only when LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
MODEL_NAME=llama3:latest

MAX_UPLOAD_BYTES=15728640
RATE_LIMIT_PER_MINUTE=120
MAX_QUERY_CHARS=12000

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=OmniAI

# Persist API/model/token metrics to PostgreSQL (disable if DB unavailable)
ENABLE_USAGE_TRACKING=true

CHAT_HISTORY_MESSAGE_LIMIT=8
CONVERSATION_SUMMARY_MIN_MESSAGES=6
CONVERSATION_SUMMARY_MAX_CHARS=4000

EVAL_ADMIN_EMAILS=
ANALYTICS_ADMIN_EMAILS=

ENABLE_DEEP_RESEARCH=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Railway: set DATABASE_URL=${{Postgres.DATABASE_URL}} instead of individual POSTGRES_* vars
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=omniai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

CHROMA_DB_PATH=./chroma_db
COLLECTION_NAME=omniai_docs

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
