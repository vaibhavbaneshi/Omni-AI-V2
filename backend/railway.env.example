# Railway production environment (set in Railway dashboard → Variables)

ENVIRONMENT=production
LLM_PROVIDER=groq
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant
GROQ_REASONING_MODEL=llama-3.3-70b-versatile
GROQ_GEMMA_MODEL=gemma2-9b-it

# Optional — DeepSeek for coding routes (OpenAI-compatible API)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Automatic model selection (set false to always use GROQ_MODEL)
MODEL_ROUTING_ENABLED=true

JWT_SECRET_KEY=<strong-32+-char-secret>
API_PUBLIC_URL=https://<your-backend>.up.railway.app
FRONTEND_URL=https://omni-ai-v2-frontend.vercel.app
CORS_ORIGINS=https://omni-ai-v2-frontend.vercel.app

# Preferred on Railway — single managed Postgres URL
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Migrations run automatically on backend startup (alembic upgrade head)

# Fallback if not using DATABASE_URL (Railway Postgres plugin references)
# POSTGRES_HOST=${{Postgres.PGHOST}}
# POSTGRES_PORT=${{Postgres.PGPORT}}
# POSTGRES_DB=${{Postgres.PGDATABASE}}
# POSTGRES_USER=${{Postgres.PGUSER}}
# POSTGRES_PASSWORD=${{Postgres.PGPASSWORD}}

CHROMA_DB_PATH=/data/chroma_db
COLLECTION_NAME=omniai_docs

# Observability (optional — enable LangSmith for trace dashboards)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=OmniAI-Production
ENABLE_USAGE_TRACKING=true

# Comma-separated emails allowed to POST /evaluation/run in production
EVAL_ADMIN_EMAILS=

# OAuth (if used)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Do NOT set OLLAMA_URL on Railway unless running Ollama as a sidecar
# LLM_PROVIDER=groq is required for cloud deploys
